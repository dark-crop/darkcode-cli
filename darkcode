#!/usr/bin/env bash
# darkcode — run-from-source launcher.
#
# The TUI is built with SolidJS JSX, which Bun only transforms when the
# @opentui/solid preload is active. Bun reads a `preload` from bunfig.toml in
# its working directory, but that ties the process cwd to packages/opencode and
# would make darkcode treat the source tree as your project. Instead we resolve
# the preload to an absolute path and pass it with --preload, so Bun keeps YOUR
# current directory as the project.
#
# Works from any directory once this file is on your PATH (see README).
set -euo pipefail

# Directory of this script = the repo root (resolve symlinks so a PATH symlink works).
src="${BASH_SOURCE[0]}"
while [ -h "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  src="$(readlink "$src")"
  [[ $src != /* ]] && src="$dir/$src"
done
ROOT="$(cd -P "$(dirname "$src")" && pwd)"
OC="$ROOT/packages/opencode"

if [ ! -d "$OC/node_modules" ] && [ ! -d "$ROOT/node_modules" ]; then
  echo "darkcode: dependencies not installed. Run 'bun install' in $ROOT first." >&2
  exit 1
fi

# ── Raise the file-descriptor limit ──────────────────────────────────────────
# Bun + darkcode open many files. macOS defaults the SOFT limit to 256, which crashes startup with
# "An unknown error occurred, possibly due to low max file descriptors". Raise the soft limit toward
# the hard limit so nobody has to run `ulimit` by hand. We target a sane 10240 and NEVER the
# multi-billion value some error hints suggest - a limit that huge makes code that sizes buffers to
# the fd count misbehave (that is usually the *second* "unknown error" people hit). Failures
# (already-high, or a locked-down machine) are ignored, and we never lower an existing higher limit.
_fd_cur="$(ulimit -Sn 2>/dev/null || echo 256)"
case "$_fd_cur" in
  unlimited) : ;;
  ''|*[!0-9]*) ulimit -Sn 10240 2>/dev/null || true ;;
  *) if [ "$_fd_cur" -lt 10240 ]; then
       ulimit -Sn 10240 2>/dev/null || ulimit -Sn "$(ulimit -Hn 2>/dev/null || echo "$_fd_cur")" 2>/dev/null || true
     fi ;;
esac
unset _fd_cur

# ── Background auto-update (managed installs only) ───────────────────────────
# Like Claude Code: on launch we quietly fetch the latest source in the background so the NEXT
# start runs it. Guarded so it ONLY touches installs created by install.sh (the .darkcode-managed
# marker) - never a dev clone, where a `git reset --hard` would discard your local work.
# Disable entirely with DARKCODE_NO_UPDATE=1. Throttled to at most once every 4 hours.
darkcode_update_notice() {
  if [ -f "$ROOT/.update-pending" ]; then
    printf '\033[35m*\033[0m darkcode updated to %s (running now)\n' \
      "$(cut -c1-9 "$ROOT/.update-pending" 2>/dev/null)" >&2
    rm -f "$ROOT/.update-pending" 2>/dev/null || true
  fi
}

darkcode_maybe_update() {
  [ "${DARKCODE_NO_UPDATE:-0}" = "1" ] && return 0
  [ -f "$ROOT/.darkcode-managed" ] || return 0
  [ -d "$ROOT/.git" ] || return 0
  command -v git >/dev/null 2>&1 || return 0

  local stamp="$ROOT/.last-update-check" now last
  now="$(date +%s 2>/dev/null || echo 0)"
  last=0
  [ -f "$stamp" ] && last="$(cat "$stamp" 2>/dev/null || echo 0)"
  case "$now" in ''|*[!0-9]*) now=0 ;; esac
  case "$last" in ''|*[!0-9]*) last=0 ;; esac
  if [ "$now" -ne 0 ]; then
    [ "$((now - last))" -lt 14400 ] && return 0
    printf '%s' "$now" > "$stamp" 2>/dev/null || true
  fi

  # Detached: fetch, and if the tracked branch moved, fast-forward the source + reinstall deps.
  # The small sleep lets this launch's bun finish loading before any files change on disk.
  (
    sleep 3
    git -C "$ROOT" fetch --quiet --depth 1 origin 2>/dev/null || exit 0
    cur="$(git -C "$ROOT" rev-parse HEAD 2>/dev/null)" || exit 0
    up="$(git -C "$ROOT" rev-parse '@{u}' 2>/dev/null)" || exit 0
    [ "$cur" = "$up" ] && exit 0
    git -C "$ROOT" reset --hard --quiet '@{u}' 2>/dev/null || exit 0
    ( cd "$ROOT" && bun install --silent 2>/dev/null ) || true
    printf '%s' "$up" > "$ROOT/.update-pending" 2>/dev/null || true
  ) >/dev/null 2>&1 &
  disown 2>/dev/null || true
  return 0
}

darkcode_update_notice
darkcode_maybe_update

preload="$(cd "$OC" && bun -e 'process.stdout.write(import.meta.resolveSync("@opentui/solid/preload"))' 2>/dev/null || true)"
if [ -z "$preload" ]; then
  echo "darkcode: could not resolve @opentui/solid/preload (is 'bun install' complete?)." >&2
  exit 1
fi

exec bun --preload "$preload" "$OC/src/index.ts" "$@"
